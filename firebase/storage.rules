rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User profile pictures
    match /users/{userId}/profile-picture/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Professional documents
    match /professionals/{professionalId}/documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == professionalId;
    }

    // Medical records
    match /medical-records/{recordId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Prescriptions
    match /prescriptions/{prescriptionId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Public assets
    match /assets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
  }
}
