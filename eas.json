{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "android": {
        "release": true,
        "buildType": "apk"
      }
    },
    "production-aab": {
      "android": {
        "release": true,
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccount": "keyfile.json",
        "track": "internal"
      }
    }
  }
}
